# Megas-xlr local environment
# Copy to .env and fill. Never commit .env.

# Optional provider credentials for future model-gateway adapters.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Postgres — local Docker by default (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://megas:megas_local_dev@localhost:5433/megas_xlr

# Supabase — reserved for future cloud deploy. Not used in Phase 0.
# Leave blank for local dev. When filled, CI/staging will read it.
SUPABASE_DATABASE_URL=
# AgentOS
AGENTOS_HOST=0.0.0.0
AGENTOS_PORT=7777
AGENTOS_LOG_LEVEL=INFO

# Pinecone (skeleton only in Phase 0)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=megas-xlr-memory
